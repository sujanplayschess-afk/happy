    },
    {
      "id": 5,
      "title": "Distance",
      "lines": [
        "Things change.",
        "And yet, some people stay — in their own quiet way."
      ],
      "image": "https://images.unsplash.com/photo-1519681393784-d120267933ba?w=1920&q=80",
      "duration": 20,
      "overlay": "rgba(0,0,5,0.6)",
