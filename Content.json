    },
    {
      "id": 4,
      "title": "Shared Memories",
      "lines": [
        "Some moments don't need photographs.",
        "They live in the pause between words."
      ],
      "image": "https://images.unsplash.com/photo-1506905925346-21bda4d32df4?w=1920&q=80",
      "duration": 20,
      "overlay": "rgba(5,5,15,0.55)",
