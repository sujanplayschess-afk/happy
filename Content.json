    {
      "id": 2,
      "title": "Growing Up",
      "lines": [
        "Somewhere between then and now,",
        "she stopped being a child — quietly, gracefully."
      ],
      "image": "https://images.unsplash.com/photo-1504203700686-f21e703e5f1c?w=1920&q=80",
      "duration": 15,
      "overlay": "rgba(5,10,20,0.5)",
      "kenBurns": "zoom-out"
    },
    {
      "id": 3,
      "title": "Personality",
      "lines": [
        "She doesn't ask for attention.",
        "She just walks in — and the room shifts."
      ],
      "image": "https://images.unsplash.com/photo-1529333166437-7750a6dd5a70?w=1920&q=80",
      "duration": 15,
      "overlay": "rgba(0,10,15,0.5)",
